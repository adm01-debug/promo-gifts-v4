# ── Todos os paths ──────────────────────────────────────────────────────────

/*
  # Security
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(self), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  # CSP — espelha vercel.json exatamente
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'sha256-aTi1YOxy4JwEfroP0cXezOWT1dfTFBaVsFFsw/YMhAk=' 'sha256-AE5r7LGU2r3qBIDE8sjdlHz60ndwt80fTKX8/FGEaHs=' blob: data: https://cdn.gpteng.co https://vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https: ; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.lovable.dev https://*.lovable.app https://*.ingest.sentry.io https://*.glitchtip.io https://*.elevenlabs.io wss://*.elevenlabs.io https://api.cnpja.com https://*.bitrix24.com.br https://*.bitrix24.com https://fonts.googleapis.com https://fonts.gstatic.com https://imagedelivery.net https://*.cloudflarestream.com https://videodelivery.net; media-src 'self' blob: https:; worker-src 'self' blob: data:; frame-src 'self' https://vercel.live https://iframe.cloudflarestream.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests; report-to csp-endpoint; report-uri https://promogifts.report-uri.com/r/d/csp/enforce
  Reporting-Endpoints: csp-endpoint="https://promogifts.report-uri.com/a/d/g"

# ── Service Worker — nunca cachear ─────────────────────────────────────────
/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Service-Worker-Allowed: /

# ── Assets estáticos — cache longo ──────────────────────────────────────────
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# ── HTML — sem cache ─────────────────────────────────────────────────────────
/
  Cache-Control: no-store, no-cache, must-revalidate

/index.html
  Cache-Control: no-store, no-cache, must-revalidate

# ── Web App Manifest ──────────────────────────────────────────────────────────
/manifest.json
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
